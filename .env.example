# Скопируйте в `.env` в корне репозитория (не коммитить).
# Docker Compose подхватывает `.env` автоматически.

POSTGRES_USER=gastro
POSTGRES_PASSWORD=gastro

# Identity (HS256): для продакшена — длинная случайная строка (≥32 символов).
JWT_SECRET=gastroroute-dev-jwt-secret-key-min-32bytes

# Redis: задайте сильный пароль в продакшене (сервисы и redis используют одно значение).
REDIS_PASSWORD=devredis

# OpenTelemetry → Jaeger (в docker-compose уже заданы для API; локально без Docker: OTEL_SDK_DISABLED=true)
# OTEL_EXPORTER_OTLP_ENDPOINT=jaeger:4317
# OTEL_SERVICE_NAME=gastroroute-catalog

# Опционально: переопределить CORS для API (в compose уже заданы localhost для dev).
# CORS_ORIGINS=http://localhost,http://127.0.0.1
